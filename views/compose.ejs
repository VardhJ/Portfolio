<%- include("header"); -%>
    <h1>Compose</h1>

    <form class="" action="/compose" method="post">
      <div class="form-group">
        <label>Title</label>
        <textarea class="form-control" name="projectTitle" rows="1"></textarea>
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea class="form-control" name="projectDesc" rows="5"></textarea>
      </div>
      <div class="form-group">
        <label>Link</label>
        <textarea class="form-control" name="projectLink" rows="1"></textarea>
      </div>
      <div class="form-group">
        <label>Rating (out of 10)</label>
        <input type="number" name="projectRating" />
      </div>
      <button type="submit" class="btn btn-primary">Publish</button>
    </form>


<%- include("footer"); -%>
